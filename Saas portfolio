<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sarosh Malik — B2B SaaS Content & Funnel Strategist</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f4f0;
    --gray: #888;
    --light-gray: #d0d0d0;
    --mid-gray: #555;

    /* 8px spacing scale */
    --space-1: 8px;
    --space-2: 16px;
    --space-3: 24px;
    --space-4: 32px;
    --space-5: 40px;
    --space-6: 48px;
    --space-7: 64px;
    --space-8: 80px;
    --space-9: 96px;
    --space-10: 120px;

    /* Layout */
    --container-max: 1080px;
    --container-pad: 40px;
    --section-pad-v: 120px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--white);
    background-image:
      linear-gradient(rgba(10,10,10,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10,10,10,0.03) 1px, transparent 1px);
    background-size: 28px 28px;
    color: var(--black);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--white); }
  ::-webkit-scrollbar-thumb { background: var(--black); }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    background: rgba(245,244,240,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(10,10,10,0.08);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--black);
  }

  .stickman-nav svg {
    width: 28px;
    height: 36px;
  }

  .nav-logo-text {
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--black);
  }

  .nav-menu-btn {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--black);
    padding: 8px 16px;
    cursor: pointer;
    color: var(--black);
    transition: all 0.2s;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-menu {
    position: relative;
  }

  .nav-menu-btn:hover {
    background: var(--black);
    color: var(--white);
  }

  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--white);
    border: 1px solid var(--black);
    min-width: 200px;
    display: none;
    flex-direction: column;
    z-index: 200;
  }

  .dropdown.open { display: flex; }

  .dropdown a {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--black);
    padding: 14px 20px;
    border-bottom: 1px solid rgba(10,10,10,0.08);
    transition: background 0.15s;
  }

  .dropdown a:last-child { border-bottom: none; }
  .dropdown a:hover { background: var(--black); color: var(--white); }

  /* ─── SECTIONS ─── */
  section {
    min-height: 100vh;
    padding: var(--section-pad-v) 0 var(--space-8);
    border-bottom: 1px solid rgba(10,10,10,0.1);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
    padding-left: var(--container-pad);
    padding-right: var(--container-pad);
  }

  @media (max-width: 1024px) {
    :root {
      --container-pad: 32px;
      --section-pad-v: 96px;
    }
  }

  @media (max-width: 768px) {
    :root {
      --container-pad: 20px;
      --section-pad-v: 80px;
    }
  }

  /* ─── STICKMAN SECTION HEADER ─── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-7);
  }

  .stickman-small svg {
    width: 36px;
    height: 48px;
  }

  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
  }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-bottom: 1px solid rgba(10,10,10,0.1);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--section-pad-v) var(--container-pad) var(--space-8);
    width: 100%;
  }

  .hero-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .hero-text h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 4vw, 58px);
    font-weight: 600;
    font-style: italic;
    line-height: 1.15;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .hero-text h1 em {
    font-style: italic;
    font-weight: 300;
  }

  .hero-subline {
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-bottom: 12px;
    font-weight: 500;
  }

  .hero-descriptor {
    font-size: 15px;
    color: var(--mid-gray);
    font-weight: 300;
    line-height: 1.6;
    max-width: 420px;
    margin-bottom: 32px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--white);
    background: var(--black);
    padding: 12px 24px;
    border: 1px solid var(--black);
    transition: all 0.2s;
  }

  .hero-cta:hover {
    background: transparent;
    color: var(--black);
  }

  .hero-photo-wrap {
    position: relative;
  }

  .hero-photo {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center 15%;
    border: 1px solid rgba(10,10,10,0.12);
    filter: grayscale(100%);
    display: block;
  }

  .hero-photo-label {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    background: var(--black);
    color: var(--white);
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 10px 16px;
    text-align: center;
  }

  .hero-stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid rgba(10,10,10,0.12);
    border-left: 1px solid rgba(10,10,10,0.12);
  }

  .hero-stat {
    padding: 24px 28px;
    border-right: 1px solid rgba(10,10,10,0.12);
    border-bottom: 1px solid rgba(10,10,10,0.12);
  }

  .hero-stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 700;
    display: block;
    margin-bottom: 4px;
  }

  .hero-stat-label {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
  }

  /* ─── TICKER ─── */
  .ticker-wrap {
    overflow: hidden;
    background: var(--black);
    color: var(--white);
    padding: 14px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .ticker-track {
    display: flex;
    white-space: nowrap;
    animation: ticker 8s linear infinite;
  }

  .ticker-item {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0 48px;
    flex-shrink: 0;
  }

  .ticker-sep {
    opacity: 0.4;
    margin: 0 16px;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ─── ABOUT ─── */
  #about .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.15;
    margin-bottom: 36px;
    letter-spacing: -0.01em;
  }

  .about-body p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--mid-gray);
    font-weight: 300;
    margin-bottom: 20px;
  }

  .about-body p:last-child { margin-bottom: 0; }

  .about-aside {
    padding-top: 8px;
  }

  .about-photo {
    width: 100%;
    max-width: 380px;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(100%);
    border: 1px solid rgba(10,10,10,0.12);
    margin-bottom: 32px;
    display: block;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid rgba(10,10,10,0.3);
    padding: 6px 12px;
    color: var(--mid-gray);
  }

  /* ─── SERVICES ─── */
  #services {
    background: var(--black);
    color: var(--white);
    background-image:
      linear-gradient(rgba(245,244,240,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,244,240,0.04) 1px, transparent 1px),
      linear-gradient(rgba(245,244,240,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,244,240,0.015) 1px, transparent 1px);
    background-size: 56px 56px, 56px 56px, 14px 14px, 14px 14px;
  }

  #services .section-label { color: rgba(245,244,240,0.4); }

  #services .stickman-small svg path,
  #services .stickman-small svg circle { stroke: var(--white); }

  .services-intro {
    max-width: 640px;
    margin-bottom: 64px;
  }

  .services-intro h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--white);
  }

  .services-intro p {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(245,244,240,0.55);
    font-weight: 300;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(245,244,240,0.12);
  }

  .service-item {
    border-bottom: 1px solid rgba(245,244,240,0.12);
    padding: 32px 0;
    display: grid;
    grid-template-columns: 48px 1fr 24px;
    gap: 24px;
    align-items: start;
    cursor: pointer;
    transition: all 0.2s;
  }

  .service-item:hover { background: rgba(245,244,240,0.03); }

  .service-num {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: rgba(245,244,240,0.3);
    padding-top: 4px;
  }

  .service-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--white);
    line-height: 1.3;
  }

  .service-toggle {
    font-size: 20px;
    color: rgba(245,244,240,0.4);
    line-height: 1;
    padding-top: 6px;
    transition: transform 0.3s;
    user-select: none;
  }

  .service-item.open .service-toggle { transform: rotate(45deg); }

  .service-body {
    display: none;
    grid-column: 2 / 3;
    font-size: 15px;
    line-height: 1.8;
    color: rgba(245,244,240,0.9);
    font-weight: 300;
    padding-top: 16px;
  }

  .service-item.open .service-body { display: block; }

  .service-body strong {
    color: #fff;
    font-weight: 500;
    display: block;
    margin-bottom: 14px;
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .service-scope {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(245,244,240,0.1);
  }

  .service-scope p {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    letter-spacing: 0;
    color: rgba(245,244,240,0.7);
    margin-bottom: 8px;
    line-height: 1.7;
  }

  .services-blunt {
    margin-top: 64px;
    padding: 40px;
    border: 1px solid rgba(245,244,240,0.15);
    max-width: 700px;
  }

  .services-blunt p {
    font-size: 14px;
    line-height: 1.75;
    color: rgba(245,244,240,0.6);
    font-weight: 300;
    margin-bottom: 12px;
  }

  .services-blunt p:last-child { margin-bottom: 0; }

  .services-blunt .blunt-title {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245,244,240,0.4);
    margin-bottom: 20px;
  }

  /* ─── WORK ─── */
  #work .work-nav {
    display: flex;
    gap: 0;
    border: 1px solid rgba(10,10,10,0.15);
    margin-bottom: 64px;
    overflow: visible;
    flex-wrap: nowrap;
  }

  @media (max-width: 768px) {
    #work .work-nav {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #work .work-nav::-webkit-scrollbar { display: none; }
    .spec-dropdown-menu {
      position: fixed;
      top: auto;
      left: 20px;
      right: 20px;
      min-width: unset;
      z-index: 500;
    }
  }

  .work-tab {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px 24px;
    cursor: pointer;
    border-right: 1px solid rgba(10,10,10,0.15);
    white-space: nowrap;
    transition: all 0.2s;
    background: none;
    border-top: none;
    border-left: none;
    border-bottom: none;
    color: var(--gray);
    position: relative;
  }

  .work-tab:last-child { border-right: none; }
  .work-tab.active { background: var(--black); color: var(--white); }
  .work-tab:hover:not(.active) { background: rgba(10,10,10,0.04); color: var(--black); }

  /* Spec Work dropdown */
  .work-tab-group {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(10,10,10,0.15);
  }

  .work-tab-group .work-tab {
    border-right: none;
    border-bottom: 1px solid rgba(10,10,10,0.15);
  }

  .work-tab-group .work-tab.active {
    background: var(--black);
    color: var(--white);
  }

  .work-sub-tabs {
    display: flex;
    border-top: none;
  }

  .work-sub-tab {
    font-family: 'Syne', sans-serif;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: none;
    border: none;
    border-right: 1px solid rgba(10,10,10,0.15);
    padding: 10px 14px;
    cursor: pointer;
    color: var(--gray);
    transition: all 0.2s;
    flex: 1;
    text-align: center;
  }

  .work-sub-tab:last-child { border-right: none; }
  .work-sub-tab:hover { background: rgba(10,10,10,0.04); color: var(--black); }
  .work-sub-tab.active { background: rgba(10,10,10,0.06); color: var(--black); font-weight: 600; }

  .work-panel { display: none; }
  .work-panel.active { display: block; }

  /* Revenue System Thinking */
  .case-study-card {
    border: 1px solid rgba(10,10,10,0.12);
    margin-bottom: 2px;
  }

  .case-study-header {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 32px 36px;
    cursor: pointer;
    transition: background 0.15s;
  }

  .case-study-header:hover { background: rgba(10,10,10,0.02); }

  .case-num {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--gray);
  }

  .case-title-block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .case-meta {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
  }

  .case-arrow {
    font-size: 18px;
    transition: transform 0.2s;
    color: var(--mid-gray);
  }

  .case-study-card.open .case-arrow { transform: rotate(90deg); }

  .case-body {
    display: none;
    padding: 0 36px 40px;
    border-top: 1px solid rgba(10,10,10,0.08);
  }

  .case-study-card.open .case-body { display: block; }

  .case-section {
    margin-top: 32px;
  }

  .case-section-title {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(10,10,10,0.08);
  }

  .case-section p {
    font-size: 14px;
    line-height: 1.8;
    color: var(--mid-gray);
    font-weight: 300;
    margin-bottom: 12px;
  }

  .case-section p:last-child { margin-bottom: 0; }

  .case-list {
    list-style: none;
    margin-top: 8px;
  }

  .case-list li {
    font-size: 13px;
    line-height: 1.7;
    color: var(--mid-gray);
    font-weight: 300;
    padding: 6px 0;
    border-bottom: 1px solid rgba(10,10,10,0.05);
    padding-left: 16px;
    position: relative;
  }

  .case-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 6px;
    height: 1px;
    background: var(--light-gray);
  }

  .two-col-case {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 12px;
  }

  .col-block h4 {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 10px;
  }

  .positioning-statement {
    margin-top: 28px;
    padding: 24px 28px;
    background: var(--black);
    color: var(--white);
  }

  .positioning-statement p {
    font-size: 13px;
    line-height: 1.75;
    color: rgba(245,244,240,0.7);
    font-weight: 300;
    margin-bottom: 8px;
  }

  .positioning-statement p:last-child { margin-bottom: 0; }

  /* SEO Work */
  .seo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .seo-card {
    border: 1px solid rgba(10,10,10,0.12);
    padding: 32px 36px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .seo-card:hover { background: var(--black); color: var(--white); }

  .seo-card-num {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--gray);
    margin-bottom: 16px;
    display: block;
  }

  .seo-card:hover .seo-card-num { color: rgba(245,244,240,0.4); }

  .seo-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .seo-card p {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--gray);
  }

  .seo-card:hover p { color: rgba(245,244,240,0.5); }

  /* ─── PIPELINE OS ─── */
  :root {
    --po-blue: #1a56f0;
    --po-red: #e8213b;
    --po-amber: #f5a623;
    --po-green: #00c48c;
    --po-ink: #0d0d14;
    --po-paper: #fafaf8;
    --po-rule: rgba(13,13,20,0.1);
  }

  #pipelineos {
    background: var(--po-paper);
    color: var(--po-ink);
    background-image:
